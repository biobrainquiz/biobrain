<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BioBrain - Home</title>
    <link rel="stylesheet" href="/css/desktopStyle.css" />

</head>

<body>
    <%- include('../../partials/desktop/header') %>

        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-overlay"></div>
            <h2>Master Life Sciences with Smart Quizzes</h2>
            <p>Challenge yourself with quizzes in Zoology, Botany, Genetics, Ecology & More.</p>
            <div>
                <button class="btn-primary">Start Quiz</button>
                <button class="btn-secondary">View Leaderboard</button>
            </div>
        </section>

        <!-- Quiz Categories -->
        <section class="section">
            <h3>Quiz Categories</h3>
            <div class="card-container">
                <div class="card">
                    <h4>NEET</h4>
                    <p>Zoology</p>
                    <button onclick="mockTest('E1','S1')">Start</button>
                </div>
                <div class="card">
                    <h4>DL/JL/Asst. Prof.</h4>
                    <p>Zoology</p>
                    <button onclick="mockTest('E2','S1')">Start</button>
                </div>
                <div class="card">
                    <h4>CSIR.NET/SLET/SET</h4>
                    <p>Life Sciences</p>
                    <button onclick="mockTest('E3','S2')">Start</button>
                </div>
                <div class="card">
                    <h4>GATE</h4>
                    <p>Zoology</p>
                    <button onclick="mockTest('E4','S1')">Start</button>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section class="section">
            <h3>Why Choose BioBrain?</h3>
            <div class="features">
                <div class="feature-box">✔ 1000+ MCQs across topics</div>
                <div class="feature-box">✔ Instant Results & Explanations</div>
                <div class="feature-box">✔ Track Your Progress</div>
                <div class="feature-box">✔ Compete on Leaderboard</div>
            </div>
        </section>

        <!-- Leaderboard Section -->
        <section class="leaderboard">
            <h3>🏆 Top Biology Minds</h3>

            <table class="leaderboard-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Name</th>
                        <th>Score</th>
                        <th>Accuracy</th>
                    </tr>
                </thead>
                <tbody>
                    <% console.log("EJS leaderboard:", leaderboard); %>
                    <% console.log("EJS leaderboard:", leaderboard.length); %>
                    <% if (leaderboard && leaderboard.length> 0) { %>

                        <% leaderboard.forEach((user, index)=> { %>
                            <tr
                                class="<%= currentuser && currentuser._id.toString() === user._id.toString() ? 'current-user' : '' %>">
                                <td>
                                    <%= index + 1 %>
                                </td>
                                <td>
                                    <%= user.username %>
                                </td>
                                <td>
                                    <%= user.finalscore %>
                                </td>
                                <td>
                                    <%= user.accuracy %>%
                                </td>
                            </tr>
                            <% }) %>

                                <% } else { %>
                                    <tr>
                                        <td colspan="4">No data available</td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </section>

        <script>
            function mockTest(examcode, subjectcode) {
                window.location.href = `/mocktest/init/${examcode}/${subjectcode}`;
            }
        </script>
        </script>
        <%- include('../../partials/desktop/footer') %>
</body>

</html>